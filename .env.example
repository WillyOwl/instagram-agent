# Instagram credentials
INSTAGRAM_USERNAME=your_instagram_username
INSTAGRAM_PASSWORD=your_instagram_password

# Ollama settings
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3
OLLAMA_EMBED_MODEL=nomic-embed-text

# Fixed-Model provider selector. Currently only 'ollama' is implemented.
# Add new fixed-model backends here in the future.
FIXED_MODEL_PROVIDER=ollama

# ── Configurable-Model pathway (LiteLLM) ─────────────────────────────────────
# Set ACTIVE_MODEL to use LiteLLM instead of the fixed-model backend.
# Leave blank to use the FIXED_MODEL_PROVIDER path.
#
# Provider prefix determines which LLM API key is required:
#   gpt-4o                          → OPENAI_API_KEY
#   anthropic/claude-3-5-sonnet-... → ANTHROPIC_API_KEY
#   gemini/gemini-pro               → GEMINI_API_KEY
#   xiaomi_mimo/mimo-v2.5           → XIAOMI_MIMO_API_KEY
#   xiaomi_mimo/mimo-v2.5-pro       → XIAOMI_MIMO_API_KEY
#   ollama/llama3                   → (local, no key needed)
ACTIVE_MODEL=

# Optional: switchable embedding model via LiteLLM.
# Leave blank to use Ollama embeddings (local) even on the Configurable path.
#   text-embedding-3-small          → OPENAI_API_KEY
ACTIVE_EMBED_MODEL=

# Optional: custom base URL / endpoint for the Active Model (e.g. for custom proxies,
# or Xiaomi Token Plans, e.g. https://token-plan-cn.xiaomimimo.com/v1)
ACTIVE_API_BASE=

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
XIAOMI_MIMO_API_KEY=

# Polling interval (seconds). Keep >= 30 to avoid account flags.
POLL_INTERVAL_SECONDS=45

# Path to your Instagram JSON export directory
# Should contain subfolders like: inbox/<thread_name>/message_1.json
HISTORY_PATH=data/instagram_export/messages/

# Comma-separated list of Instagram usernames allowed to receive auto-replies
# Example: SENDER_WHITELIST=alice,bob,charlie
SENDER_WHITELIST=
